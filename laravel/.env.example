# ==========================================================================
# Be Better BSBL — Laravel Environment Configuration
# Copy this file to .env and fill in production values.
# ==========================================================================

APP_NAME="Be Better BSBL"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# --------------------------------------------------------------------------
# Database — MariaDB 10.11 on Cloudways
# --------------------------------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bebetter_store
DB_USERNAME=root
DB_PASSWORD=

# --------------------------------------------------------------------------
# Session / Cache / Logging
# --------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=bebetter_session
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=

CACHE_STORE=file
CACHE_PREFIX=bebetter_cache

CACHE_TTL_PRODUCT=300
CACHE_TTL_COLLECTION=300
CACHE_TTL_SEARCH=120
CACHE_TTL_HOME=600

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=info
LOG_DAILY_DAYS=14

# --------------------------------------------------------------------------
# Hashing
# --------------------------------------------------------------------------
HASH_DRIVER=bcrypt
BCRYPT_ROUNDS=12

# --------------------------------------------------------------------------
# Filesystem
# --------------------------------------------------------------------------
FILESYSTEM_DISK=local

# --------------------------------------------------------------------------
# Admin User Seed (used by AdminUserSeeder)
# --------------------------------------------------------------------------
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@bebetterbsbl.com
ADMIN_PASSWORD=ChangeMeInProduction!

# --------------------------------------------------------------------------
# Query Profiling (optional)
# --------------------------------------------------------------------------
QUERY_LOG_ENABLED=false
QUERY_LOG_SLOW_MS=100
QUERY_LOG_MAX_COUNT=20
