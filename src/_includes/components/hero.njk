{#
  HERO (Homepage) — Phase 2 parity

  Usage:
    {% from "components/hero.njk" import hero %}
    {{ hero() }}
#}

{% macro hero(content = {}) %}
<section class="hero hero--home" aria-label="Hero">
  <div class="container hero__container">
    <div class="hero-grid hero-grid--home">
      <div class="hero-copy">
        <h1 class="hero-title hero-title--home">
          <span>ONES WHO PUT</span>
          <span>IN THE WORK</span>
        </h1>

        <p class="hero-lede">
          Every piece we make is inspired by the game and driven by one mindset:
        </p>
        <p class="hero-strong">
          <strong>Show up. Put in the work. Be Better.</strong>
        </p>

        <div class="hero__cta">
          <a class="btn btn-primary btn-lg" href="/collections/men/">SHOPNOW</a>
        </div>

        {# Removed hero-promo as requested #}
      </div>

      <div class="hero-media">
        <div class="hero-frame" aria-hidden="true">
          <img data-cms="hero.image" src="{{ content.image or '/assets/img/placeholder.jpg' }}" alt="{{ content.alt or '' }}" loading="eager" decoding="async" />
        </div>
      </div>
    </div>
  </div>
</section>
{% endmacro %}
