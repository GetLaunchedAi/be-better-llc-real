{# Header + announcement bar (design parity foundation) #}
{% set currentUrl = page.url or "/" %}

<header class="site-header">
  <div class="announcement" role="region" aria-label="Announcement">
    <div class="announcement__inner">
      <div class="announcement__track">
        <span class="announcement__item">40% OFF ON ALL PRODUCTS</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
        <span class="announcement__item">FREE SHIPPING ON ORDERS $50+</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
        <span class="announcement__item">HASSLE-FREE EXCHANGES</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
        <span class="announcement__item">30-DAY RETURNS</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
      </div>

      {# Duplicate track for visual repetition (no JS marquee) #}
      <div class="announcement__track" aria-hidden="true">
        <span class="announcement__item">40% OFF ON ALL PRODUCTS</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
        <span class="announcement__item">FREE SHIPPING ON ORDERS $50+</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
        <span class="announcement__item">HASSLE-FREE EXCHANGES</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
        <span class="announcement__item">30-DAY RETURNS</span>
        <span class="announcement__sep" aria-hidden="true">//</span>
      </div>
    </div>
  </div>

  <div class="header-bar">
    <div class="container header-inner">
      <a class="brand" href="/" aria-label="Home">
        <span class="brand-mark" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L20.5 5.5V12.6C20.5 17.1 17.6 20.2 12 22C6.4 20.2 3.5 17.1 3.5 12.6V5.5L12 2Z" stroke="currentColor" stroke-width="1.6"/>
            <path d="M10 7.2H13.2C15 7.2 16.2 8.1 16.2 9.6C16.2 10.6 15.6 11.3 14.7 11.6C15.8 11.9 16.6 12.8 16.6 14C16.6 15.8 15.2 16.8 13.2 16.8H10V7.2ZM11.8 11.1H13C13.9 11.1 14.4 10.6 14.4 9.9C14.4 9.2 13.9 8.8 13 8.8H11.8V11.1ZM11.8 15.2H13.1C14.1 15.2 14.7 14.7 14.7 13.9C14.7 13.1 14.1 12.6 13.1 12.6H11.8V15.2Z" fill="currentColor"/>
          </svg>
        </span>
        <span class="brand-text">
          <span class="brand-name">BE BETTER.</span>
          <span class="brand-sub">BSBL.</span>
        </span>
      </a>

      <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        <span class="sr-only">Toggle navigation</span>
        <span class="nav-toggle-lines" aria-hidden="true"></span>
      </button>

      <div class="nav-backdrop" data-nav-backdrop aria-hidden="true"></div>

      <nav id="site-nav" class="site-nav" aria-label="Primary">
        <div class="nav-drawer__top">
          <span class="nav-drawer__title">MENU</span>
          <button class="nav-close" type="button" data-nav-close aria-label="Close navigation">✕</button>
        </div>

        <div class="nav-items">
          <a class="nav-link nav-link--primary {% if currentUrl == '/collections/sale/' %}is-active{% endif %}" href="/collections/sale/">
            HOLIDAYDEALS <span class="nav-caret" aria-hidden="true">▾</span>
          </a>
          <a class="nav-link nav-link--primary {% if currentUrl == '/collections/men/' %}is-active{% endif %}" href="/collections/men/">
            MENS <span class="nav-caret" aria-hidden="true">▾</span>
          </a>
          <a class="nav-link nav-link--primary {% if currentUrl == '/collections/women/' %}is-active{% endif %}" href="/collections/women/">
            WOMENS <span class="nav-caret" aria-hidden="true">▾</span>
          </a>
          <a class="nav-link nav-link--primary" href="/collections/bags/">
            BAGS <span class="nav-caret" aria-hidden="true">▾</span>
          </a>
          <a class="nav-link nav-link--primary" href="/collections/gear/">
            GEAR <span class="nav-caret" aria-hidden="true">▾</span>
          </a>
          <a class="nav-link nav-link--primary {% if currentUrl == '/collections/youth/' %}is-active{% endif %}" href="/collections/youth/">
            YOUTH <span class="nav-caret" aria-hidden="true">▾</span>
          </a>

          <a class="nav-link nav-link--mobileonly" href="/search/#focus">SEARCH</a>
          <a class="nav-link nav-link--mobileonly" href="/cart/">
            CART <span class="cart-badge" data-cart-count aria-label="Cart items">0</span>
          </a>
        </div>

        <div class="nav-drawer__divider" aria-hidden="true"></div>

        <div class="nav-drawer__meta">
          <a class="nav-link nav-link--muted" href="/shipping/">Shipping</a>
          <a class="nav-link nav-link--muted" href="/returns/">Returns</a>
          <a class="nav-link nav-link--muted" href="/privacy/">Privacy</a>
          <a class="nav-link nav-link--muted" href="/terms/">Terms</a>
        </div>
      </nav>

      <div class="header-actions" aria-label="Header actions">
        <a class="icon-btn" href="/search/#focus" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M10.5 18.5C14.6421 18.5 18 15.1421 18 11C18 6.85786 14.6421 3.5 10.5 3.5C6.35786 3.5 3 6.85786 3 11C3 15.1421 6.35786 18.5 10.5 18.5Z" stroke="currentColor" stroke-width="1.8"/>
            <path d="M16.2 16.2L21 21" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"/>
          </svg>
        </a>

        <a class="icon-btn" href="/account/" aria-label="Account">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M12 12.5C14.4853 12.5 16.5 10.4853 16.5 8C16.5 5.51472 14.4853 3.5 12 3.5C9.51472 3.5 7.5 5.51472 7.5 8C7.5 10.4853 9.51472 12.5 12 12.5Z" stroke="currentColor" stroke-width="1.8"/>
            <path d="M4.5 20.5C5.9 17.6 8.7 16 12 16C15.3 16 18.1 17.6 19.5 20.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"/>
          </svg>
        </a>

        <a class="icon-btn icon-btn--cart" href="/cart/" aria-label="Cart">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M6.5 8.5H20.5L19 18.5H8L6.5 8.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
            <path d="M8 8.5L7.2 5.5H3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="square"/>
            <path d="M10 21C10.5523 21 11 20.5523 11 20C11 19.4477 10.5523 19 10 19C9.44772 19 9 19.4477 9 20C9 20.5523 9.44772 21 10 21Z" fill="currentColor"/>
            <path d="M17 21C17.5523 21 18 20.5523 18 20C18 19.4477 17.5523 19 17 19C16.4477 19 16 19.4477 16 20C16 20.5523 16.4477 21 17 21Z" fill="currentColor"/>
          </svg>
          <span class="cart-badge cart-badge--icon" data-cart-count aria-label="Cart items">0</span>
        </a>
      </div>
    </div>
  </div>
</header>
