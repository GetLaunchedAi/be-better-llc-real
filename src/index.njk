---
layout: layouts/base.njk
title: Home
description: Be Better storefront homepage.
---

{% from "components/hero.njk" import hero %}
{% from "components/section-header.njk" import sectionHeader %}
{% from "components/product-card.njk" import productCard %}
{% from "components/promo-tiles.njk" import promoTiles %}
{% from "components/featured-promos.njk" import featuredPromos %}

{{ hero(homepageContent.hero) }}

<section id="youth" class="section section-home">
  <div class="container">
    {{ sectionHeader({
      eyebrow: "SHOP BY CATEGORY",
      title: products.youthCollection.title,
      subtitle: "",
      ctaText: "VIEW ALL",
      ctaUrl: (products.youthCollection.ctaUrl | default("/collections/youth/"))
    }) }}

    <div class="product-grid product-grid--tight" aria-label="Youth Collection products">
      {% for p in products.youthCollection.products %}
        {{ productCard(p, { variant: "giveaway" }) }}
      {% endfor %}
    </div>
  </div>
</section>

<section id="new-arrivals" class="section section-home section-home--tight">
  <div class="container">
    <div class="new-arrivals-banner" aria-label="New Arrivals banner">
      <img class="new-arrivals-banner__img" data-cms="newArrivals.bannerImage" src="{{ homepageContent.newArrivals.bannerImage or '/assets/img/placeholder.jpg' }}" alt="{{ homepageContent.newArrivals.bannerAlt or '' }}" loading="lazy" decoding="async" />
      <div class="new-arrivals-banner__content">
        <h2 class="new-arrivals-banner__title">NEW ARRIVALS</h2>
        <div class="new-arrivals-banner__actions" aria-label="New arrivals quick links">
          <a class="btn btn-primary btn-sm new-arrivals-banner__btn" href="/collections/men/">SHOPNEWMENS</a>
          <a class="btn btn-primary btn-sm new-arrivals-banner__btn" href="/collections/women/">SHOPNEWWOMENS</a>
        </div>
      </div>
    </div>

    <div class="product-grid product-grid--tight" aria-label="New Arrivals products">
      {% for p in products.newArrivals.products %}
        {{ productCard(p, { variant: "giveaway" }) }}
      {% endfor %}
    </div>
  </div>
</section>

<section id="deals" class="section section-home section-alt section-home--tight">
  <div class="container">
    <div class="deals-head">
      <div>
        <h2 class="deals-title">HOLIDAY DEALS</h2>
        <p class="deals-subtitle">Shopping and gifting made easy with holiday deals.</p>
      </div>
      <a class="btn btn-outline btn-sm" href="/collections/sale/">VIEW ALL <span aria-hidden="true">→</span></a>
    </div>

    {{ promoTiles([
      {
        kicker: products.holidayDeals.tiles[0].kicker,
        headline: products.holidayDeals.tiles[0].headline,
        ctaText: products.holidayDeals.tiles[0].ctaText,
        url: products.holidayDeals.tiles[0].url,
        image: homepageContent.holidayDeals.tiles[0].image or products.holidayDeals.tiles[0].image,
        alt: homepageContent.holidayDeals.tiles[0].alt or ''
      },
      {
        kicker: products.holidayDeals.tiles[1].kicker,
        headline: products.holidayDeals.tiles[1].headline,
        ctaText: products.holidayDeals.tiles[1].ctaText,
        url: products.holidayDeals.tiles[1].url,
        image: homepageContent.holidayDeals.tiles[1].image or products.holidayDeals.tiles[1].image,
        alt: homepageContent.holidayDeals.tiles[1].alt or ''
      }
    ]) }}
  </div>
</section>

<section id="headwear" class="section section-home">
  <div class="container">
    <h2 class="section-title section-title--solo">HEADWEAR</h2>

    <div class="product-grid product-grid--tight" aria-label="Headwear products">
      {% for p in products.headwear.products %}
        {{ productCard(p, { variant: "giveaway" }) }}
      {% endfor %}
    </div>

    <div class="center-cta">
      <a class="btn btn-outline btn-sm" href="/collections/headwear/">VIEW ALL <span aria-hidden="true">→</span></a>
    </div>
  </div>
</section>

<section id="grip" class="section section-home section-home--tight">
  <div class="container">
    <div class="grip-split">
      <div class="grip-copy">
        <h2 class="grip-title">GRIP IT &amp; RIP IT</h2>
        <p class="grip-kicker">Simple mindset. No hesitation.</p>
        <p class="grip-text">The Grip It &amp; Rip It Tee captures the fearless confidence every hitter needs stepping into the box.</p>

        <ul class="grip-bullets" role="list">
          <li>Lightweight and comfortable</li>
          <li>Durable for active play</li>
          <li>Bold design inspired by the game</li>
        </ul>

        <p class="grip-text">Step up. Swing free.</p>

        <a class="btn btn-outline btn-sm grip-btn" href="/about/">READ OUR STORY</a>
      </div>

      <div class="grip-media" aria-hidden="true">
        <img class="grip-media__img" data-cms="grip.mainImage" src="{{ homepageContent.grip.mainImage or '/assets/img/placeholder.jpg' }}" alt="{{ homepageContent.grip.mainAlt or '' }}" loading="lazy" decoding="async" />
      </div>
    </div>

    <div class="grip-tiles" aria-label="Grip section tiles">
      <div class="grip-tile"><img data-cms="grip.tiles.0.image" src="{{ homepageContent.grip.tiles[0].image or '/assets/img/placeholder.jpg' }}" alt="{{ homepageContent.grip.tiles[0].alt or '' }}" loading="lazy" decoding="async" /></div>
      <div class="grip-tile"><img data-cms="grip.tiles.1.image" src="{{ homepageContent.grip.tiles[1].image or '/assets/img/placeholder.jpg' }}" alt="{{ homepageContent.grip.tiles[1].alt or '' }}" loading="lazy" decoding="async" /></div>
      <div class="grip-tile"><img data-cms="grip.tiles.2.image" src="{{ homepageContent.grip.tiles[2].image or '/assets/img/placeholder.jpg' }}" alt="{{ homepageContent.grip.tiles[2].alt or '' }}" loading="lazy" decoding="async" /></div>
    </div>
  </div>
</section>

<section id="featured" class="section section-home section-alt">
  <div class="container">
    {{ sectionHeader({
      eyebrow: "FEATURED PROMOS",
      title: "FEATURED PROMOS",
      subtitle: "",
      ctaText: "",
      ctaUrl: ""
    }) }}

    {{ featuredPromos([
      {
        caption: products.featuredPromos.tiles[0].caption,
        url: products.featuredPromos.tiles[0].url,
        image: homepageContent.featuredPromos.tiles[0].image or products.featuredPromos.tiles[0].image,
        alt: homepageContent.featuredPromos.tiles[0].alt or ''
      },
      {
        caption: products.featuredPromos.tiles[1].caption,
        url: products.featuredPromos.tiles[1].url,
        image: homepageContent.featuredPromos.tiles[1].image or products.featuredPromos.tiles[1].image,
        alt: homepageContent.featuredPromos.tiles[1].alt or ''
      },
      {
        caption: products.featuredPromos.tiles[2].caption,
        url: products.featuredPromos.tiles[2].url,
        image: homepageContent.featuredPromos.tiles[2].image or products.featuredPromos.tiles[2].image,
        alt: homepageContent.featuredPromos.tiles[2].alt or ''
      }
    ]) }}
  </div>
</section>

<script>
(function(){
  fetch('/homepage-content.json')
    .then(function(r){return r.ok?r.json():null})
    .then(function(d){
      if(!d)return;
      function resolve(obj,path){
        return path.split('.').reduce(function(o,k){return o&&o[k]},obj);
      }
      document.querySelectorAll('[data-cms]').forEach(function(el){
        var val=resolve(d,el.dataset.cms);
        if(val&&val!=='/assets/img/placeholder.jpg') el.src=val;
      });
      if(d.holidayDeals&&d.holidayDeals.tiles){
        var deals=document.querySelectorAll('.promo-deal');
        d.holidayDeals.tiles.forEach(function(t,i){
          if(deals[i]&&t.image) deals[i].style.backgroundImage="url('"+t.image+"')";
        });
      }
      if(d.featuredPromos&&d.featuredPromos.tiles){
        var promos=document.querySelectorAll('.featured-promo__img');
        d.featuredPromos.tiles.forEach(function(t,i){
          if(promos[i]&&t.image) promos[i].src=t.image;
        });
      }
    })
    .catch(function(){});
})();
</script>
