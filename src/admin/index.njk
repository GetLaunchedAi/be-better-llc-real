---
layout: layouts/base.njk
title: Admin
description: Product admin (edits /products.json live).
---

<section class="section section-tight">
  <div class="container">
    <div class="page-head">
      <h1 class="page-title">Admin</h1>
      <p class="muted page-subtitle">Edit products live. Changes write directly to <code>/products.json</code> on the server (no Eleventy rebuild).</p>
    </div>

    <div class="card" data-admin-root>
      <div data-admin-login>
        <h2 class="card-title">Sign in</h2>
        <p class="muted">Password is read from the <code>ADMIN_PASSWORD</code> server environment variable.</p>

        <form class="form" data-login-form>
          <div class="form-row">
            <label class="label" for="admin-pass">Password</label>
            <input class="input" id="admin-pass" name="password" type="password" autocomplete="current-password" required />
          </div>

          <button class="btn btn-primary" type="submit">Log in</button>
          <p class="muted" data-login-error style="margin-top:12px; display:none;"></p>
        </form>
      </div>

      <div data-admin-app hidden>
        <div class="admin-bar" style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
          <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap;">
            <strong>Products</strong>
            <span class="muted" data-admin-status>Loading…</span>
          </div>
          <button class="btn btn-ghost btn-sm" type="button" data-admin-logout>Logout</button>
        </div>

        <hr class="divider" />

        <div class="admin-grid">
          <div class="admin-left">
            <div class="form-row">
              <label class="label" for="admin-search">Search</label>
              <input class="input" id="admin-search" type="search" placeholder="Search products…" data-admin-search />
            </div>

            <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom: 12px;">
              <button class="btn btn-primary btn-sm" type="button" data-admin-add>Add new</button>
              <button class="btn btn-outline btn-sm" type="button" data-admin-export>Export JSON</button>
              <button class="btn btn-outline btn-sm" type="button" data-admin-import>Import JSON</button>
              <button class="btn btn-ghost btn-sm" type="button" data-admin-refresh>Refresh</button>
              <input type="file" accept="application/json" data-admin-import-file hidden />
            </div>

            <div class="admin-list" data-admin-list></div>
          </div>

          <div class="admin-right">
            <h2 class="card-title" style="margin-bottom:10px;">Editor</h2>
            <p class="muted" data-admin-empty>Pick a product on the left to edit, or create a new one.</p>

            <form class="form" data-admin-form hidden>
              <div class="form-row">
                <label class="label" for="f-id">ID</label>
                <input class="input" id="f-id" type="text" data-f="id" />
              </div>

              <div class="form-row">
                <label class="label" for="f-slug">Slug</label>
                <input class="input" id="f-slug" type="text" data-f="slug" placeholder="auto-from-title" />
              </div>

              <div class="form-row">
                <label class="label" for="f-title">Title</label>
                <input class="input" id="f-title" type="text" data-f="title" required />
              </div>

              <div class="form-row">
                <label class="label" for="f-subtitle">Subtitle</label>
                <input class="input" id="f-subtitle" type="text" data-f="subtitle" />
              </div>

              <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                <div class="form-row">
                  <label class="label" for="f-price">Price</label>
                  <input class="input" id="f-price" type="text" data-f="price" placeholder="29.99" required />
                </div>

                <div class="form-row">
                  <label class="label" for="f-compare">Compare at</label>
                  <input class="input" id="f-compare" type="text" data-f="compareAt" placeholder="39.99" />
                </div>
              </div>

              <div class="form-row">
                <label class="label" for="f-badge">Badge</label>
                <input class="input" id="f-badge" type="text" data-f="badge" placeholder="Sale" />
              </div>

              <div class="form-row">
                <label class="label" for="f-badges">Badges (comma)</label>
                <input class="input" id="f-badges" type="text" data-f="badges" placeholder="New, Best" />
              </div>

              <div class="form-row">
                <label class="label" for="f-collections">Collections (comma)</label>
                <input class="input" id="f-collections" type="text" data-f="collections" placeholder="men, sale" />
              </div>

              <div class="form-row">
                <label class="label" for="f-tags">Tags (comma)</label>
                <input class="input" id="f-tags" type="text" data-f="tags" placeholder="new, polos" />
              </div>

              <div class="form-row">
                <label class="label" for="f-image">Image</label>
                <input class="input" id="f-image" type="text" data-f="image" placeholder="/assets/img/placeholder.jpg" />
                <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:10px; align-items:center;">
                  <button class="btn btn-outline btn-sm" type="button" data-admin-upload>Upload image</button>
                  <input type="file" accept="image/*" data-admin-upload-file hidden />
                  <span class="muted" data-admin-upload-status></span>
                </div>
              </div>

              <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top: 14px;">
                <button class="btn btn-primary" type="submit" data-admin-save>Save</button>
                <button class="btn btn-ghost" type="button" data-admin-delete>Delete</button>
              </div>

              <p class="muted" data-admin-error style="margin-top:12px; display:none;"></p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="/assets/js/admin.js" defer></script>
